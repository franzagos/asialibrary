# Copy this file to .env and fill in the values marked [REQUIRED].

# DATABASE [REQUIRED]
# Local dev: run `docker compose up -d` and use the URL below as-is.
# Production: replace with your Neon connection string (neon.tech).

POSTGRES_URL="postgresql://dev_user:dev_password@localhost:5432/app_dev"

# AUTH [REQUIRED]
# Generate a secret: openssl rand -base64 32

BETTER_AUTH_SECRET="CHANGE-ME-generate-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:3000"

# GOOGLE OAUTH [OPTIONAL] — enables "Sign in with Google"
# Get credentials: console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to register: http://localhost:3000/api/auth/callback/google

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI [OPTIONAL] — required if your app uses AI features
# Get key: openrouter.ai/settings/keys — Browse models: openrouter.ai/models

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4.1-mini"

# EMAIL [OPTIONAL] — required if your app sends email
# Get key: resend.com/api-keys — From address must be from a verified domain.

RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# FILE STORAGE [OPTIONAL] — leave empty to use local storage in dev
# Production: Vercel Dashboard → Storage → Create Blob Store

BLOB_READ_WRITE_TOKEN=""

# APP URL [REQUIRED]
# Change to your production domain when deploying.

NEXT_PUBLIC_APP_URL="http://localhost:3000"
